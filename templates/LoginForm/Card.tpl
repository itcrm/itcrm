<div style="width:160px; padding:20px 12px; border:1px solid #ccc; border-radius:6px; background:#fff; text-align:center; cursor:pointer; transition:box-shadow 0.15s, transform 0.15s, border-color 0.15s;"
     onmouseover="this.style.borderColor='#6699cc'; this.style.boxShadow='0 2px 8px rgba(0,0,0,0.12)'; this.style.transform='translateY(-2px)';"
     onmouseout="this.style.borderColor='#ccc'; this.style.boxShadow=''; this.style.transform='';"
     onclick="LoginAs('[:Login:]')">
    <img style="width:96px; height:96px; border-radius:50%; background:#f4f4f4; margin-bottom:10px;" src="https://api.dicebear.com/7.x/avataaars/svg?seed=[:Login:]&clothesColor=[:AvatarColor:]" alt="" />
    <div style="font-weight:bold; color:#003399; word-break:break-word;">[:Name:]</div>
    <div style="color:#888; font-size:12px; word-break:break-word; margin-top:2px;">[:Login:]</div>
</div>
